# 공통 인프라 환경변수 — 모든 에이전트가 공유. 안정 prefix 유지(에이전트 prefix 안 붙임).
# 에이전트 고유값은 agents/<x>/.env.agent.example 참조.

# 플랫폼
ENVIRONMENT=dev               # dev | staging | prod
LOG_FORMAT=text               # text(로컬) | json(운영)
ALLOWED_ORIGINS=              # 쉼표구분 CORS origin

# LLM 게이트웨이 (공통)
LLM_BASE_URL=
LLM_VERIFY_SSL=1

# 캐시/큐
REDIS_URL=

# 오브젝트 스토리지(아카이브) — 기본 off
S3_RAW_ARCHIVE_ENABLED=0
S3_RAW_ARCHIVE_BUCKET=
S3_RAW_ARCHIVE_REGION=

# PII — 가명화 기본 off
PII_PSEUDONYMIZE=0
PII_CIPHER_KEY=
